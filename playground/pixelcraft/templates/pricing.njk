{% extends "layout.njk" %}

{% block content %}
  <main class="page-shell page-narrow">
    <section class="pricing-card">
      <h1>Pricing</h1>
      <div class="pricing-grid">
        {% for tier in pricing %}
          <article class="tier-card">
            <h2>{{ tier.name }}</h2>
            <p class="price">{{ tier.price }}</p>
            <p>{{ tier.detail }}</p>
          </article>
        {% endfor %}
      </div>
    </section>
  </main>
{% endblock %}
